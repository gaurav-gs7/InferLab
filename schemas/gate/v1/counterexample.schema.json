{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inferlab.ai/schemas/gate/v1/counterexample.schema.json",
  "title": "InferLab Counterexample v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "name", "concurrency", "requests", "fault"],
  "properties": {
    "schema": {"const": "inferlab.counterexample"}, "schema_version": {"const": "1.0"},
    "name": {"$ref": "#/$defs/name"}, "concurrency": {"type": "integer", "minimum": 1, "maximum": 4096},
    "requests": {"type": "array", "minItems": 1, "maxItems": 10000, "items": {"$ref": "#/$defs/request"}},
    "fault": {"$ref": "evaluation.schema.json#/$defs/fault"}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "arrival_offset_milliseconds", "prompt_tokens", "output_tokens", "tenant"],
      "properties": {
        "id": {"$ref": "#/$defs/name"}, "arrival_offset_milliseconds": {"type": "integer", "minimum": 0, "maximum": 86400000},
        "prompt_tokens": {"type": "integer", "minimum": 1, "maximum": 1048576}, "output_tokens": {"type": "integer", "minimum": 1, "maximum": 1048576},
        "tenant": {"$ref": "#/$defs/name"}
      }
    }
  }
}
