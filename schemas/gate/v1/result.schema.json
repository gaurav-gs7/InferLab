{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inferlab.ai/schemas/gate/v1/result.schema.json",
  "title": "InferLab GateResult v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "evaluation", "evaluation_digest", "change_digest", "decision", "findings", "coverage", "admissions", "graph"],
  "properties": {
    "schema": {"const": "inferlab.gate-result"}, "schema_version": {"const": "1.0"},
    "evaluation": {"$ref": "#/$defs/name"}, "evaluation_digest": {"$ref": "#/$defs/digest"}, "change_digest": {"$ref": "#/$defs/digest"},
    "decision": {"enum": ["PASS", "BLOCK", "INCONCLUSIVE"]},
    "findings": {"type": "array", "minItems": 1, "maxItems": 1536, "items": {"$ref": "#/$defs/finding"}},
    "coverage": {"type": "array", "maxItems": 128, "items": {"$ref": "#/$defs/coverage"}},
    "admissions": {"type": "array", "maxItems": 512, "items": {"$ref": "#/$defs/admission"}},
    "graph": {"type": "array", "minItems": 1, "maxItems": 8192, "items": {"$ref": "#/$defs/graph_node"}}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "code": {"enum": ["within-policy", "violation-risk", "uncertainty-overlap", "missing-coverage", "out-of-distribution", "missing-metric", "invalid-metric", "missing-uncertainty", "under-sampled", "incomplete-evidence", "non-observed-evidence", "stale-evidence", "future-evidence", "runtime-incompatible", "runtime-unknown"]},
    "finding": {
      "type": "object", "additionalProperties": false,
      "required": ["rule_id", "region", "outcome", "code", "metric", "semantics", "threshold", "message"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/name"}, "region": {"$ref": "#/$defs/name"}, "outcome": {"enum": ["pass", "block", "inconclusive"]}, "code": {"$ref": "#/$defs/code"},
        "evidence_digest": {"$ref": "#/$defs/digest"}, "metric": {"$ref": "#/$defs/name"}, "semantics": {"$ref": "#/$defs/name"},
        "observed_value": {"type": "number"}, "lower_bound": {"type": "number"}, "upper_bound": {"type": "number"},
        "threshold": {"type": "number"}, "violation_probability": {"type": "number", "minimum": 0, "maximum": 1}, "message": {"type": "string", "minLength": 1, "maxLength": 1024}
      }
    },
    "coverage": {
      "type": "object", "additionalProperties": false, "required": ["region", "candidate_digests", "admitted_digests", "covered"],
      "properties": {"region": {"$ref": "#/$defs/name"}, "candidate_digests": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/digest"}}, "admitted_digests": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/digest"}}, "covered": {"type": "boolean"}}
    },
    "compatibility": {
      "type": "object", "required": ["status"],
      "properties": {"status": {"enum": ["exact", "compatible-by-policy", "incompatible", "unknown"]}, "policy_name": {"type": "string"}, "policy_version": {"type": "string"}, "differences": {"type": "array", "items": {"type": "string"}}, "ignored_differences": {"type": "array", "items": {"type": "string"}}, "unknown_dimensions": {"type": "array", "items": {"type": "string"}}},
      "additionalProperties": false
    },
    "admission": {
      "type": "object", "additionalProperties": false, "required": ["evidence_digest", "status", "compatibility"],
      "properties": {"evidence_digest": {"$ref": "#/$defs/digest"}, "status": {"enum": ["accepted", "rejected"]}, "codes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/code"}}, "compatibility": {"$ref": "#/$defs/compatibility"}}
    },
    "graph_node": {
      "type": "object", "additionalProperties": false, "required": ["id", "kind", "depends_on"],
      "properties": {"id": {"$ref": "#/$defs/name"}, "kind": {"enum": ["runtime", "workload", "artifact", "evidence", "calibration", "policy", "claim", "decision"]}, "depends_on": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}}}
    }
  }
}
