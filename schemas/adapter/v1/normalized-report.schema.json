{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inferlab.ai/schemas/adapter/v1/normalized-report.schema.json",
  "title": "InferLab NormalizedReport v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "adapter", "input_digest", "originals", "mappings", "envelope"],
  "properties": {
    "schema": {"const": "inferlab.normalized-report"},
    "schema_version": {"const": "1.0"},
    "adapter": {"$ref": "#/$defs/adapter"},
    "input_digest": {"$ref": "#/$defs/digest"},
    "originals": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/original"}},
    "mappings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/mapping"}},
    "envelope": {"$ref": "../../evidence/v1/envelope.schema.json"}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"},
    "identifier": {"type": "string", "minLength": 1, "maxLength": 256},
    "revision": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "adapter": {
      "type": "object", "additionalProperties": false, "required": ["name", "revision"],
      "properties": {"name": {"$ref": "#/$defs/name"}, "revision": {"$ref": "#/$defs/revision"}}
    },
    "original": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "definition", "value", "unit", "sample_count"],
      "properties": {
        "name": {"$ref": "#/$defs/name"}, "definition": {"$ref": "#/$defs/name"},
        "value": {"type": "number"}, "unit": {"$ref": "#/$defs/identifier"},
        "sample_count": {"type": "integer", "minimum": 1}
      }
    },
    "mapping": {
      "type": "object", "additionalProperties": false,
      "required": ["source_name", "source_definition", "source_value", "source_unit", "normalized_name", "semantics", "normalized_value", "normalized_unit", "scale", "offset"],
      "properties": {
        "source_name": {"$ref": "#/$defs/name"}, "source_definition": {"$ref": "#/$defs/name"},
        "source_value": {"type": "number"}, "source_unit": {"$ref": "#/$defs/identifier"},
        "normalized_name": {"$ref": "#/$defs/name"}, "semantics": {"$ref": "#/$defs/name"},
        "normalized_value": {"type": "number"}, "normalized_unit": {"$ref": "#/$defs/identifier"},
        "scale": {"type": "number"}, "offset": {"type": "number"}
      }
    }
  }
}
