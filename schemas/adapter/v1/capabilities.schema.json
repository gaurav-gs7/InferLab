{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inferlab.ai/schemas/adapter/v1/capabilities.schema.json",
  "title": "InferLab AdapterCapabilities v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "adapter", "producer", "classifications", "metrics"],
  "properties": {
    "schema": {"const": "inferlab.adapter-protocol"},
    "schema_version": {"const": "1.0"},
    "adapter": {"$ref": "#/$defs/adapter"},
    "producer": {"$ref": "#/$defs/producer"},
    "classifications": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["observed", "predicted"]}},
    "metrics": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/metric"}}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"},
    "identifier": {"type": "string", "minLength": 1, "maxLength": 256},
    "revision": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "revision"],
      "properties": {"name": {"$ref": "#/$defs/name"}, "revision": {"$ref": "#/$defs/revision"}}
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "tool_version", "report_schema"],
      "properties": {
        "tool": {"$ref": "#/$defs/name"},
        "tool_version": {"$ref": "#/$defs/identifier"},
        "report_schema": {"$ref": "#/$defs/identifier"}
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_name", "source_definition", "source_unit", "normalized_name", "semantics", "normalized_unit"],
      "properties": {
        "source_name": {"$ref": "#/$defs/name"},
        "source_definition": {"$ref": "#/$defs/name"},
        "source_unit": {"$ref": "#/$defs/identifier"},
        "normalized_name": {"$ref": "#/$defs/name"},
        "semantics": {"$ref": "#/$defs/name"},
        "normalized_unit": {"$ref": "#/$defs/identifier"}
      }
    }
  }
}
